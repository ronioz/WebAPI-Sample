# Secrets / local env
.env
venv/
node_modules/
__pycache__/
*.pyc
.Python

# IDE
.idea/
.vscode/
*.iml

# Pulled source clones (regenerated by pull_source.py)
data/*/
**/.openapi-export/

# Generated pipeline outputs (regenerated by Cursor / OpenAPI steps)
data/*.openapi.json
data/*.readme.md
data/*.intro.md
data/*.json

# Keep the data/ directory in git
!data/.gitkeep

# Local demos / build leftovers (not part of the pipeline)
samples/
artifacts/
**/bin/
**/obj/

# Local run logs
*.log
openapi_run_log.txt

# Sample app local
*.user
.vs/

