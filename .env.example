# --- In-repo source (this checkout IS the API) ---
# Leave SOURCE_REPO_URL empty for local/CI when you --skip-pull
SOURCE_REPO_DIR=.
OPENAPI_MODULE_NAME=SampleWebApiAspNetCore
OPENAPI_PROJECT=SampleWebApiAspNetCore/SampleWebApiAspNetCore.csproj

# --- Optional: pull a remote copy into data/ instead ---
# SOURCE_REPO_URL=https://github.com/YOUR_USER/WebAPI-Sample.git
# SOURCE_REPO_DIR=data/WebAPI-Sample

# --- Cursor (docs steps) ---
# CURSOR_API_KEY=
# CURSOR_MODEL=auto

# --- Apidog upload ---
APIDOG_BASE_URL=
APIDOG_PROJECT_ID=
APIDOG_ACCESS_TOKEN=
APIDOG_MODULE_MAP=apidog_modules.json
# APIDOG_VERIFY_SSL=false

# --- Email (optional) ---
# REPORT_EMAIL_TO=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
